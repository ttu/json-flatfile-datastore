<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <!-- xunit.v3 ships its targets in buildTransitive, so they flow here through
         the test ProjectReference and inject a second Main. This is not a test
         project, so suppress that generated entry point. -->
    <XunitAutoGeneratedEntryPoint>false</XunitAutoGeneratedEntryPoint>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="BenchmarkDotNet" Version="0.15.8"/>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\JsonFlatFileDataStore.Test\JsonFlatFileDataStore.Test.csproj"/>
    <ProjectReference Include="..\JsonFlatFileDataStore\JsonFlatFileDataStore.csproj"/>
  </ItemGroup>

</Project>
